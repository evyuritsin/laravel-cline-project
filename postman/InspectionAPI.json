{
	"info": {
		"_postman_id": "inspection-api-mvp",
		"name": "Move-in/out Inspection API",
		"description": "API для приложения осмотра квартир при заселении/выселении (MVP)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Request OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"79001234567\"\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/request-otp",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "auth", "request-otp"]
						},
						"description": "Запрос OTP кода на телефон. Возвращает debug_code в development режиме. Rate limit: 3 запроса в минуту."
					},
					"response": []
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"79001234567\",\n  \"code\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/verify-otp",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "auth", "verify-otp"]
						},
						"description": "Верификация OTP кода. При успехе возвращает токен и данные пользователя. Код действителен 5 минут, максимум 3 попытки проверки."
					},
					"response": []
				},
				{
					"name": "Telegram Login (Legacy)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"telegram_id\": 123456789,\n  \"name\": \"Иван Петров\",\n  \"avatar_url\": \"https://example.com/avatar.jpg\"\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/auth/telegram",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "auth", "telegram"]
