				{
					"name": "Geocode Address",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/geocode?address=Москва",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "geocode"],
							"query": [
								{
									"key": "address",
									"value": "Москва",
									"description": "Адрес для геокодирования"
