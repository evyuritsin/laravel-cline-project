					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/reverse-geocode?latitude=55.7558&longitude=37.6173",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "reverse-geocode"],
							"query": [
								{
									"key": "latitude",
									"value": "55.7558",
									"description": "Широта"
								},
								{
									"key": "longitude",
									"value": "37.6173",
									"description": "Долгота"
								}
							]
						},
						"description": "Получение адреса по координатам (обратное геокодирование)"
