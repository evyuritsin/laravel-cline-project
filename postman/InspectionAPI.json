					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{TOKEN}}"
							}
						],
						"url": {
							"raw": "{{BASE_URL}}/api/auth/logout",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "auth", "logout"]
